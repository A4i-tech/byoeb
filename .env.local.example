# ============================================================
# BYOEB Local Setup — Minimal Required Variables
# Copy to .env.local and fill in your values
# ============================================================

# --- LLM (Required) ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORG_ID=

# --- WhatsApp (Required for bot to receive/send messages) ---
WHATSAPP_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=any-string-you-choose-for-webhook-verification

# --- Database (MongoDB via Docker Compose) ---
MONGO_DB_CONNECTION_STRING=mongodb://mongodb:27017/byoeb

# --- Auth (generate a random secret) ---
AUTH_TOKEN_SECRET=change-me-to-a-random-32-char-string
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_TOKEN_ALGORITHM=HS256
AUTH_TOKEN_ISSUER=byoeb
AUTH_TOKEN_AUDIENCE=byoeb

# --- Local Backends (no Azure needed) ---
QUEUE_PROVIDER=kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=byoeb
KAFKA_TOPIC_BOT=byoeb-bot
KAFKA_TOPIC_STATUS=byoeb-status
KAFKA_TOPIC_DEAD_LETTER=byoeb-dlq
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/local_media_storage
VECTOR_STORE_TYPE=llama_index_chroma
PERSIST_DIRECTORY=/app/vector_db

# Qdrant (only needed if VECTOR_STORE_TYPE=qdrant)
# QDRANT_LOCATION=:memory:        # in-memory, no Docker
# QDRANT_HOST=localhost            # Docker qdrant service
# QDRANT_PORT=6333
# QDRANT_URL=                      # Qdrant Cloud URL
# QDRANT_API_KEY=                  # Qdrant Cloud API key
# QDRANT_COLLECTION_NAME=byoeb-kb

# --- App ---
APP_ENV=LOCAL

# ============================================================
# Azure variables below are NOT needed for local setup.
# Only fill these if QUEUE_PROVIDER=azure_storage_queue or
# STORAGE_BACKEND=azure or VECTOR_STORE_TYPE=azure_vector_search
# ============================================================

# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_BLOB_ACCOUNT_URL=
# AZURE_STORAGE_CONTAINER_NAME=
# AZURE_STORAGE_QUEUE_ACCOUNT_URL=
# AZURE_QUEUE_STATUS=
# AZURE_QUEUE_BOT=
# AZURE_QUEUE_DEAD_LETTER=
# AZURE_SEARCH_SERVICE_NAME=
# AZURE_SEARCH_INDEX_NAME=
# AZURE_SEARCH_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT_NAME=
# AZURE_OPENAI_KEY=
# AZURE_COGNITIVE_KEY=
# AZURE_COGNITIVE_REGION=
# AZURE_COGNITIVE_TEXT_TO_TEXT_RESOURCE=
# AZURE_COGNITIVE_TEXT_TO_SPEECH_RESOURCE=
