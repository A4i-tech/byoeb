# Keys and credentials related to Open AI LLM [url: https://azure.microsoft.com/en-in/products/ai-services/openai-service]
# Note: This will depend on the type of API (OpenAI or Azure OpenAI) you are using. Below is for Azure OpenAI keys.
export OPENAI_API_KEY_EMBED=<openai-embedding-key>
export OPENAI_API_KEY=<openai-api-key>
export OPENAI_API_ENDPOINT=<openai-api-endpoint>
export OPENAI_API_TYPE=<openai-api-type>
export OPENAI_API_VERSION=<openai-api-version>
export OPENAI_ORG_ID=<openai-org-id>
#
# Azure OpenAI (used when APP_ENV / keys.env drive config; can overlap with above)
export AZURE_OPENAI_ENDPOINT=<azure-openai-endpoint>
export AZURE_OPENAI_DEPLOYMENT_NAME=<azure-openai-deployment-name>
export AZURE_OPENAI_KEY=<azure-openai-key>
export AZURE_OPENAI_SPEECH_ENDPOINT=<azure-openai-speech-endpoint>
export AZURE_OPENAI_WHISPER_KEY=<azure-openai-whisper-key>
#
# Keys for Azure Translator and Azure Speech services [url: https://azure.microsoft.com/en-us/products/ai-services/ai-translator and https://azure.microsoft.com/en-us/products/ai-services/speech-to-text]
# Note: We use the same region for both language translation and speech-to-text/text-to-speech services
export AZURE_TRANSLATION_KEY=<az-translation-key>
export AZURE_SPEECH_KEY=<az-speech-key>
export AZURE_REGION=<az-region>
export AZURE_COGNITIVE_KEY=<az-cognitive-key>
export AZURE_COGNITIVE_REGION=<az-cognitive-region>
export AZURE_COGNITIVE_TEXT_TO_SPEECH_RESOURCE=<az-cognitive-tts-resource-id>
export AZURE_COGNITIVE_TEXT_TO_TEXT_RESOURCE=<az-cognitive-tts-resource-id>
#
# Credentials for Azure message queue, for processing WhatsApp messages
export AZURE_QUEUE_NAME=<az-message-queue-name>
# Environment-specific queue names (required when using keys.env for production/staging separation)
export AZURE_QUEUE_STATUS=<az-queue-status-name>
export AZURE_QUEUE_BOT=<az-queue-bot-name>
export AZURE_QUEUE_DEAD_LETTER=<az-queue-dead-letter-name>
#
# Credentials for Azure database, for storing interaction logs (we are using MongoDB)
export COSMOS_DB_CONNECTION_STRING=<az-cosmos-db-connection-string>
export MONGO_DB_CONNECTION_STRING=<mongo-db-connection-string>
#
# Credentials for Azure blob storage, for storing input audio files
export AZURE_STORAGE_CONNECTION_STRING=<az-blob-storage-connection-string>
export AZURE_STORAGE_BLOB_ACCOUNT_URL=<az-storage-blob-account-url>
export AZURE_STORAGE_QUEUE_ACCOUNT_URL=<az-storage-queue-account-url>
export AZURE_STORAGE_CONTAINER_NAME=<az-storage-container-name>
export AZURE_STORAGE_ANALYSIS_CONTAINER_NAME=<az-storage-analysis-container-name>
#
# Azure Cognitive Search (vector search / KB)
export AZURE_SEARCH_API_KEY=<az-search-api-key>
export AZURE_SEARCH_SERVICE_NAME=<az-search-service-name>
export AZURE_SEARCH_INDEX_NAME=<az-search-index-name>
#
# Monitoring and logging
export OTEL_PYTHON_DISABLED_INSTRUMENTATIONS=<otel-disabled-instrumentations>
export APPINSIGHTS_CONNECTION_STRING=<appinsights-connection-string>
export APP_LOGGER_NAME=<app-logger-name>
#
# Crendentials for using WhatsApp [url: https://developers.facebook.com/]
export WHATSAPP_TOKEN=<whatsapp-token>
export WHATSAPP_VERIFICATION_TOKEN=<whatsapp-verification-token>
export WHATSAPP_AUTH_TOKEN=<whatsapp-auth-token>
export PHONE_NUMBER_ID=<whatsapp-phone-number-id>
#
# Optional app/uat flags (used when running with keys.env-driven config)
export APP_ENV=<app-env>
export ASHABOT_UAT=<ashabot-uat-0-or-1>
export RECIEVE_URL=<receive-url>
export USER_NAME=<user-name>
export TEST_USERS_ONLY=<true-or-false>
#
# APP_PATH is the abolute path of this project folder (either your local PC path, or your deployed Azure VM path)
export APP_PATH=<insert-absolute-path-here>
#
# DATA_PATH is the path to the data folder (which contains knowledge base raw document, knowledge base vector DB, onboarding messages, etc.).
# Note: DATA_PATH should be relative to the APP_PATH
export DATA_PATH=<data-path>
#
# Note: Please do not change below, it is required.
export SSL_CERT_DIR=/etc/ssl/certs
export VERIFY_TOKEN='12345'
#
echo "Keys imported"