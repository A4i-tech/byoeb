{
    "_comment": "This file contains non-sensitive configuration defaults. Production-specific resource URLs and credentials should be set via environment variables in keys.env. See keys.env for production configuration.",
    "app":{
        "batch_size": 5,
        "azure_cognitive_endpoint": "https://cognitiveservices.azure.com/.default",
        "queue_provider": "azure_storage_queue",
        "queue_retry_count": 3,
        "db_provider": "azure_cosmos_mongo_db",
        "history_length": 3,
        "max_last_active_duration_seconds": 86400
    },
    "channel": {
        "whatsapp": {
            "allowed_message_types": [
                "audio",
                "text"
            ],
            "reuse_client": true
        },
        "reaction": {
            "enabled": false,
            "user": {
                "resolved": "✅",
                "verified": "✅",
                "rejected": "❌",
                "pending": "⏳"
            },
            "expert": {
                "resolved": "✅",
                "pending": "⏳",
                "waiting": "✏️"
            }
        }
    },
    "databases": {
        "mongo_db":
        {
            "provider_type": "azure_cosmos_mongo_db",
            "dyk_collection": "ashadyks",
            "user_collection": "ashausers",
            "message_collection": "ashamessages",
            "jobs_collection": "ashajobs",
            "_comment": "Override MONGO_DB_DATABASE_NAME via environment variables for production"
        }
    },
    "embeddings": {
        "azure": {
            "model": "text-embedding-3-large",
            "deployment_name": "text-embedding-3-large",
            "api_version": "2023-03-15-preview",
            "_comment": "Override AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_DEPLOYMENT_NAME via environment variables for production"
        }
    },
    "llms": {
        "azure": {
            "model": "gpt-4o",
            "deployment_name": "gpt-4o",
            "api_version": "2023-03-15-preview",
            "_comment": "Override AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_DEPLOYMENT_NAME via environment variables for production"
        },
        "openai": {
            "model": "gpt-4o-2024-08-06",
            "api_version": "2023-03-15-preview"
        }
    },
    "media_storage": {
        "azure": {
            "_comment": "Override AZURE_STORAGE_BLOB_ACCOUNT_URL and AZURE_STORAGE_CONTAINER_NAME via environment variables for production"
        }
    },
    "message_queue": {
        "azure": {
            "queue_status": "statusmessages",
            "queue_bot": "botmessages",
            "dead_letter_queue": "deadletterqueue",
            "messages_per_page": 5,
            "visibility_timeout": 180,
            "time_to_live": 604800,
            "_comment": "Override AZURE_STORAGE_QUEUE_ACCOUNT_URL via environment variables for production"
        }
    },
    "translators": {
        "speech": [
            {
                "motive": "text_to_speech",
                "service": "azure_cognitive",
                "languages": ["en", "hi", "mr", "te"]
            },
            {
                "motive": "speech_to_text",
                "service": "azure_openai",
                "languages": ["en", "hi", "mr", "te"],
                "attributes": {"model": "whisper", "api_version": "2024-10-21"}
            },
            {
                "motive": "speech_to_text",
                "service": "azure_openai",
                "languages": ["en", "hi", "te"],
                "attributes": {"model": "gpt-4o-transcribe", "api_version": "2024-10-21"},
                "gated": true
            },
            {
                "motive": "speech_to_text",
                "service": "azure_openai",
                "languages": ["mr"],
                "attributes": {"model": "whisper", "api_version": "2024-10-21"},
                "gated": true
            }
        ],
        "text": {
            "azure_cognitive": {}
        }
    },
    "vector_store": {
        "chroma": {
            "doc_index_name": "vector_collection"
        },
        "llama_index_chroma": {
            "doc_index_name": "vector_collection"
        },
        "azure_vector_search": {
            "_comment": "Override AZURE_SEARCH_SERVICE_NAME and AZURE_SEARCH_INDEX_NAME via environment variables for production"
        }
    },
    "app_logger": {
        "azure": {
            "_comment": "Override APP_LOGGER_NAME via environment variables for production"
        }
    }
}
